  "homepage": "https://github.com/RatanNarayanHegde/notesBackend#readme",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.1",
    "express": "^4.17.3",
    "express-async-errors": "^3.1.1",
    "mongoose": "^6.3.2"
  },
  "devDependencies": {
    "eslint": "^8.15.0",
    "jest": "^28.1.0",
